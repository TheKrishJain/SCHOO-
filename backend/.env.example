# Backend environment example
# Copy to .env and adjust values

SECRET_KEY=change-me-in-production
DEBUG=True

# DATABASE OPTIONS:
# Option 1: SQLite (Development - Current)
DATABASE_URL=sqlite:///db.sqlite3

# Option 2: PostgreSQL (Production - Recommended)
# Uncomment and update after PostgreSQL setup:
# DATABASE_URL=postgresql://school_os_user:your_password_here@localhost:5432/school_os

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# EMAIL CONFIGURATION (for Password Reset)
# ============================================
# Development: Uses console backend (emails printed to terminal)
# Production: Use SMTP backend with real email server

# Email Backend Options:
# - django.core.mail.backends.console.EmailBackend (Development - prints to terminal)
# - django.core.mail.backends.smtp.EmailBackend (Production - sends real emails)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Settings (for production with Gmail, SendGrid, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# For Gmail: Enable 2FA and create an App Password
# https://support.google.com/accounts/answer/185833

# Sender and support emails
DEFAULT_FROM_EMAIL=School-OS <noreply@school-os.com>
SUPPORT_EMAIL=support@school-os.com

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000
